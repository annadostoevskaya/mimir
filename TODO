        return mimir_build_driver_rsync(ini, section, driver);
    }

    mimir_error("Unknown driver");
    return -1;
}
```

```c
struct mimir_policy_driver_rsync_config {
    int archive;
    int delete;
    int hardlinks;
    int acl;
    int xattrs;
    int numeric_ids;
};
```

---

## 14. Rsync builder

```c
static int mimir_build_driver_rsync(
    struct mimir_policy_ini *ini,
    char *section,
    struct mimir_policy_driver *driver
) {
    struct mimir_policy_driver_rsync_config *config = mimir_arena_malloc(
        &g_mimir_arena,
        sizeof(*config)
    );

    if (config == NULL) {
        mimir_error("Failed to allocate rsync driver config");
        return -1;
    }

    for (size_t i = 0; i < ini->entries_count; i += 1) {
        struct mimir_policy_entry *entry = ini->entries + i;

        if (!mimir_cstring_equals(entry->section, section)) {
            continue;
        }

        if (mimir_cstring_equals(entry->key, "archive")) {
            if (mimir_parse_bool(entry->value, &config->archive) != 0) {
                return -1;
            }

            continue;
        }

        if (mimir_cstring_equals(entry->key, "delete")) {
            if (mimir_parse_bool(entry->value, &config->delete) != 0) {
                return -1;
            }

            continue;
        }

        if (mimir_cstring_equals(entry->key, "hardlinks")) {
            if (mimir_parse_bool(entry->value, &config->hardlinks) != 0) {
                return -1;
            }

            continue;
        }

        if (mimir_cstring_equals(entry->key, "acl")) {
            if (mimir_parse_bool(entry->value, &config->acl) != 0) {
                return -1;
            }

            continue;
        }

        if (mimir_cstring_equals(entry->key, "xattrs")) {
            if (mimir_parse_bool(entry->value, &config->xattrs) != 0) {
                return -1;
            }

            continue;
        }

        if (mimir_cstring_equals(entry->key, "numeric_ids")) {
            if (mimir_parse_bool(entry->value, &config->numeric_ids) != 0) {
                return -1;
            }

            continue;
        }

        mimir_error("Unknown rsync driver key");
        return -1;
    }

    driver->type = MIMIR_POLICY_DRIVER_RSYNC;
    driver->config = config;
    driver->vtable = &mimir_policy_driver_rsync_vtable;

    return 0;
}
```

---

## 15. Главное: hash map пока не нужен

Вот это:

```c
// 1. Create domain temporary structure (hash-map)
// 1.1. O(1) access to every hm[section][key] = value
```

Я бы отложил.

Сейчас тебе нужен не hash map, а функции:

```c
mimir_read_policy_manifest()
mimir_build_source()
mimir_build_capture()
mimir_build_repository()
mimir_build_driver()
```

Потом внутри них можно заменить:

```c
for (size_t i = 0; i < ini->entries_count; i += 1)
```

на:

```c
mimir_ini_get(ini_map, section, key)
```

Но архитектура не изменится.

---

## Какой следующий минимальный шаг

Я бы сделал вот это:

```c
struct mimir_policy {
    char *title;

    struct mimir_policy_source source;
    struct mimir_policy_repository repository;
    struct mimir_policy_driver driver;
};
```

Без capture пока.

И конфиг:

```ini
[attachments]
source = fs
repository = fs
driver = rsync

[attachments.source.fs]
path = /tmp/attachments

[attachments.repository.fs]
path = /tmp/attachmes

[attachments.driver.rsync]
archive = true
delete = true
```

А `capture` добавишь следующим шагом:

```ini
capture = direct

[attachments.capture.direct]
```

Так ты не застрянешь в архитектуре, но уже будешь двигаться в правильную сторону.
